   "id": "21d0ae29-b974-4eb9-bd58-6132ed41ec39",
   "metadata": {},
   "outputs": [],
   "source": [
    "# to get actual values\n",
    "\n",
    "geo_labels = data[\"dimension\"][\"geo\"][\"category\"][\"label\"]\n",
    "time_labels = data[\"dimension\"][\"time\"][\"category\"][\"label\"]\n",
    "values = data[\"value\"]\n",
    "\n",
    "geo_list = list(geo_labels.values())\n",
    "time_list = list(time_labels.values())"
   ]
  },
