   "source": [
    "selected_countries = [\"Austria\", \"Belgium\", \"Germany\", \"France\", \"Sweden\"]\n",
    "selected_data = df_json[df_json[\"country\"].isin(selected_countries)]\n",
    "\n",
    "pivot_trend = selected_data.pivot_table(index=\"year\", columns=\"country\", values=\"pay_gap\", aggfunc=\"mean\")\n",
    "\n",
    "pivot_trend.plot(figsize=(12, 6), marker=\"o\")\n",
    "plt.title(\"Gender Pay Gap Trends in Selected Countries\")\n",
    "plt.xlabel(\"Year\")\n",
    "plt.ylabel(\"Pay Gap\")\n",
    "plt.grid(True, linestyle=\"--\", alpha=0.5)\n",
    "plt.legend(title=\"Country\")\n",
    "plt.show()\n"
   ]
  },
